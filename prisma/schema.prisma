// This is the Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // If you want types generated in a specific folder, uncomment the next line:
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- EXISTING MODELS ---

model SlabContent {
  id               String   @id @default(cuid())
  title            String
  chunk_text       String   @db.Text
  embedding_vector Float[]
  slab_url         String?
  updatedAt        DateTime @updatedAt
}

model GoogleDocsContent {
  id               String   @id @default(cuid())
  title            String
  chunk_text       String   @db.Text
  embedding_vector Float[]
  doc_url          String?
  updatedAt        DateTime @updatedAt
}

model QuestionAsked {
  id            String   @id @default(cuid())
  user_id       String
  question_text String   @db.Text
  createdAt     DateTime @default(now())
}

// --- NEW MODELS FOR COHERENT FACTS & HASHING ---

/**
 * Represents a document (PDF, Slide, or Sheet) ingested into the system.
 * The lastHash field acts as the "Gatekeeper" to prevent redundant API costs.
 */
model SourceFile {
  id        String   @id @default(cuid())
  fileName  String   @unique
  lastHash  String   // SHA-256 fingerprint of the file content
  updatedAt DateTime @updatedAt
  
  // Relation: A source file contains many extracted facts
  facts     Fact[]
}

/**
 * Represents a single "Coherent Fact" extracted by the LLM.
 * Instead of arbitrary text chunks, these are atomic units of information.
 */
model Fact {
  id           String     @id @default(cuid())
  content      String     @db.Text
  createdAt    DateTime   @default(now())
  
  // Relationship back to the source document
  sourceFile   SourceFile @relation(fields: [sourceFileId], references: [id])
  sourceFileId String
  
  // Future-proofing: Vector for RAG retrieval
  embedding_vector Float[]
}